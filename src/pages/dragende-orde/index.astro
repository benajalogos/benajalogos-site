---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="De dragende orde — Benaja Logos">

   <p class="back-link">
     <a href="/">← Terug naar Home</a>
  </p>

  <h1>Dragende orde</h1>

  <p>
     Een dragende orde verwijst naar de onderliggende ordening die leven mogelijk maakt en in balans houdt.
  </p>

  <p>
      <strong>Natuur</strong> - Alles in de natuur functioneert binnen een dragende orde.
  </p>

  <p>
     <strong>Mens</strong> - Een dragende orde zorgt dat keuzes aansluiten op wat daadwerkelijk nodig is.
  </p>

  <p>
      <strong>Wijsheid</strong> - Beschrijving van een dragende orde voor een leven in balans.
  </p>

   <p>
      Benaja Logos wil deze dragende orde zo breed mogelijk delen door de bron toegankelijk te maken en de drempel laag te houden.
  </p>


  <div class="grid grid-2 home-cta" style="margin-top:58px; margin-bottom:54px;">

      <div>
          <a class="btn" href="/benajalogos/kennismaking">Meer informatie over Benaja Logos</a>
      </div>

      <div>
         <a class="btn" href="/boeken">Meer informatie over Dragende orde</a>
      </div>

  </div>


</BaseLayout>